{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "full-debug",
      "displayName": "Full DiFfRG Debug",
      "binaryDir": "${sourceDir}/build_install",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/local_install",
        "BUILD_PETSC": "OFF"
      }
    },
    {
      "name": "full-debug-petsc",
      "displayName": "Full DiFfRG Debug With PETSc",
      "inherits": "full-debug",
      "binaryDir": "${sourceDir}/build_install_petsc",
      "cacheVariables": {
        "BUILD_PETSC": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "full-debug",
      "displayName": "Build Full DiFfRG Debug",
      "configurePreset": "full-debug",
      "jobs": 8
    },
    {
      "name": "full-debug-petsc",
      "displayName": "Build Full DiFfRG Debug With PETSc",
      "configurePreset": "full-debug-petsc",
      "jobs": 8
    }
  ]
}
