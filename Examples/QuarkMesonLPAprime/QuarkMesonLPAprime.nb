Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Set", " ", "up", " ", "the", " ", "assumptions", " ", "for", " ", "the", " ",
     "Matsubara", " ", "Sum"}], "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"$Assumptions", " ", "=", " ", 
     RowBox[{"$Assumptions", " ", "&&", " ", 
      RowBox[{"muq", ">=", "0"}], " ", "&&", 
      RowBox[{"l1", ">", "0"}], "&&", 
      RowBox[{"k", ">", "0"}], "&&", 
      RowBox[{
       RowBox[{"-", "1"}], "<", "cos", "<", "1"}], "&&", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "d1V"}], "-", 
        SuperscriptBox["l1", "2"], "-", 
        RowBox[{"RB", "[", 
         RowBox[{
          SuperscriptBox["k", "2"], ",", 
          SuperscriptBox["l1", "2"]}], "]"}]}], "<", "0"}], "&&", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "m2Sigma"}], "-", 
        SuperscriptBox["l1", "2"], "-", 
        RowBox[{"RB", "[", 
         RowBox[{
          SuperscriptBox["k", "2"], ",", 
          SuperscriptBox["l1", "2"]}], "]"}]}], "<", "0"}], "&&", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "m2Quark"}], "-", 
        SuperscriptBox["l1", "2"], "-", 
        RowBox[{"2", " ", "l1", " ", 
         RowBox[{"RF", "[", 
          RowBox[{
           SuperscriptBox["k", "2"], ",", 
           SuperscriptBox["l1", "2"]}], "]"}]}], "-", 
        SuperscriptBox[
         RowBox[{"RF", "[", 
          RowBox[{
           SuperscriptBox["k", "2"], ",", 
           SuperscriptBox["l1", "2"]}], "]"}], "2"]}], "<", "0"}]}]}], ";"}], 
   "\n", 
   RowBox[{
    RowBox[{"flowV", " ", "=", " ", 
     RowBox[{"fRGV", "/.", "diagrammaticRules"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"flowV", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"flowV", "[", "\"\<1-Loop\>\"", "]"}], 
       "[", "\"\<Expression\>\"", "]"}], "//", "FormTrace"}]}], ";"}], "\n", 
   RowBox[{"(*", " ", 
    RowBox[{
     RowBox[{
     "Need", " ", "to", " ", "change", " ", "the", " ", "notation", " ", 
      "since", " ", "ExpandScalarProductsFiniteT"}], ",", " ", 
     RowBox[{
     "need", " ", "the", " ", "loop", " ", "momentum", " ", "of", " ", 
      "fermions", " ", "to", " ", "have", " ", "the", " ", "f", " ", "at", " ",
       "the", " ", "end"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"flowV", " ", "=", " ", 
     RowBox[{
      RowBox[{"flowV", "//.", "dressingRules"}], "/.", 
      RowBox[{"lf1", "->", "l1f"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"flowV", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{"ExpandScalarProductsFiniteT", "[", "flowV", "]"}], "//.", 
       "postTraceRules"}], "//", "UseLorentzLinearity"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"flowV", " ", "=", " ", 
     RowBox[{"flowV", "//", 
      RowBox[{
       RowBox[{"SimplifyAllMomenta", "[", 
        RowBox[{"l1", ",", " ", "#"}], "]"}], "&"}]}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{"flowV", " ", "=", " ", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"flowV", "/.", 
         RowBox[{
          RowBox[{"sps", "[", 
           RowBox[{"l1", ",", " ", "l1"}], "]"}], "->", 
          RowBox[{"l1", "^", "2"}]}]}], "/.", 
        RowBox[{
         RowBox[{"sp", "[", 
          RowBox[{"l1", ",", "l1"}], "]"}], "->", 
         RowBox[{
          RowBox[{"l1", "^", "2"}], " ", "+", " ", 
          RowBox[{"l0", "^", "2"}]}]}]}], "/.", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{"a_", "^", "2"}], "]"}], ":>", "a"}]}], "/.", " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"1", "/", 
         RowBox[{"Sqrt", "[", 
          RowBox[{"a_", "^", "2"}], "]"}]}], ":>", 
        RowBox[{"1", "/", "a"}]}], ")"}]}]}], ";"}], "\n", 
   RowBox[{"(*", 
    RowBox[{
    "Add", " ", "change", " ", "of", " ", "variable", " ", "for", " ", 
     "easier", " ", "assumption", " ", "condition"}], "*)"}], "\n", 
   RowBox[{"flowV", " ", "=", " ", 
    RowBox[{
     RowBox[{
      RowBox[{"flowV", "//.", 
       RowBox[{
        RowBox[{"2", "d2V", " ", "rhoPhi"}], " ", "->", " ", 
        RowBox[{"m2Sigma", " ", "-", "d1V"}]}]}], "//.", 
      RowBox[{"hPhi", "->", 
       SqrtBox[
        FractionBox[
         RowBox[{"m2Quark", " ", "2", "Nf"}], 
         RowBox[{"2", "rhoPhi"}]]]}]}], "//", "Simplify"}]}], "\n", 
   RowBox[{
    RowBox[{"flowV", " ", "=", " ", 
     RowBox[{"Map", "[", 
