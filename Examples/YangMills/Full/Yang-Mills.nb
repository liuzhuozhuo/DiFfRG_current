             RowBox[{"p1_", ",", "p2_"}], "}"}]}], "]"}], ":>", 
          RowBox[{
           RowBox[{
            RowBox[{"ZA", "[", "evP", "]"}], 
            RowBox[{"RBdot", "[", 
