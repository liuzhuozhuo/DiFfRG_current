       RowBox[{"A", "[", 
        RowBox[{"p", ",", 
         RowBox[{"{", 
          RowBox[{"v", ",", " ", "c"}], "}"}]}], "]"}], "}"}]}], ",", "\n", 
     RowBox[{"\"\<Grassmann\>\"", "->", 
      RowBox[{"{", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"cb", "[", 
          RowBox[{"p", ",", 
           RowBox[{"{", "c", "}"}]}], "]"}], ",", 
         RowBox[{"c", "[", 
          RowBox[{"p", ",", 
           RowBox[{"{", "c", "}"}]}], "]"}]}], "}"}], "}"}]}]}], "\n", 
    "|>"}]}], ";"}]], "Input",
 InitializationCell->
  True,ExpressionUUID->"d321cec2-76da-4f13-9f96-d0da70672a1a"],

