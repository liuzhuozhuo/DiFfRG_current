Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"SP3Patt", "[", 
    RowBox[{"p1e_", ",", "p2e_", ",", "p3e_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"Sqrt", "[", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"sp", "[", 
            RowBox[{"p1", ",", "p1"}], "]"}], "+", 
           RowBox[{"sp", "[", 
            RowBox[{"p2", ",", "p2"}], "]"}], "+", 
           RowBox[{"sp", "[", 
            RowBox[{"p3", ",", "p3"}], "]"}]}], ")"}], "/", "3"}], "]"}], 
       "}"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"p1", ":>", "p1e"}], ",", 
        RowBox[{"p2", ":>", "p2e"}], ",", 
        RowBox[{"p3", ":>", "p3e"}]}], "}"}]}], "//", "UseLorentzLinearity"}],
     "//", "FullSimplify"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"SP4Patt", "[", 
     RowBox[{"p1e_", ",", "p2e_", ",", "p3e_", ",", "p4e_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"Sqrt", "[", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{
            RowBox[{"sp", "[", 
             RowBox[{"p1", ",", "p1"}], "]"}], "+", 
            RowBox[{"sp", "[", 
             RowBox[{"p2", ",", "p2"}], "]"}], "+", 
            RowBox[{"sp", "[", 
             RowBox[{"p3", ",", "p3"}], "]"}], "+", 
            RowBox[{"sp", "[", 
             RowBox[{"p4", ",", "p4"}], "]"}]}], ")"}], "/", "4"}], "]"}], 
        "}"}], "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"p1", ":>", "p1e"}], ",", 
         RowBox[{"p2", ":>", "p2e"}], ",", 
         RowBox[{"p3", ":>", "p3e"}], ",", 
         RowBox[{"p4", ":>", "p4e"}]}], "}"}]}], "//", 
      "UseLorentzLinearity"}], "//", "FullSimplify"}]}], ";"}], "\n", "\n", 
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{"Angle", "-", 
     RowBox[{"resolved", " ", "three"}], "-", 
     RowBox[{"point", " ", 
      RowBox[{"pattern", ":", " ", 
       RowBox[{"keep", " ", "the", " ", "full", " ", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{"|", "p1", "|"}], ",", 
          RowBox[{"|", "p2", "|"}], ",", 
          RowBox[{"cos", 
           RowBox[{"(", 
            RowBox[{"p1", ",", "p2"}], ")"}]}]}], ")"}], " ", 
        RowBox[{"dependence", ".", "\n", "   ", "This"}], " ", "is", " ", "a",
         " ", "vacuum", " ", 
        RowBox[{"(", 
         RowBox[{"4", "D", " ", "Euclidean"}], ")"}], " ", "computation", " ",
         "with", " ", "no", " ", 
        RowBox[{"temporal", "/", "Matsubara"}], " ", "direction"}]}]}]}], ",",
     " ", 
    RowBox[{
    "so", " ", "the", "\n", "   ", "external", " ", "angle", " ", "is", " ", 
     "the", " ", "full", " ", "4", "D", " ", "angle", " ", "and", " ", "the", 
     " ", "cosine", " ", "numerator", " ", "is", " ", "the", " ", "full", " ",
      "product", " ", 
     RowBox[{"sp", "[", 
      RowBox[{"p1", ",", "p2"}], "]"}], "\n", "   ", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"NOT", " ", "the", " ", "spatial"}], "-", 
         RowBox[{"only", " ", 
          RowBox[{"sps", "[", "..", "]"}]}]}], ",", " ", 
        RowBox[{
        "which", " ", "would", " ", "be", " ", "correct", " ", "only", " ", 
         "at", " ", "finite", " ", "temperature"}]}], ")"}], "."}]}]}], " ", 
   "*)"}]}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"P3Patt", "[", 
    RowBox[{"p1e_", ",", "p2e_", ",", "p3e_"}], "]"}], ":=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Sqrt", "[", 
         RowBox[{"sp", "[", 
          RowBox[{"p1", ",", "p1"}], "]"}], "]"}], ",", 
        RowBox[{"Sqrt", "[", 
         RowBox[{"sp", "[", 
          RowBox[{"p2", ",", "p2"}], "]"}], "]"}], ",", 
        RowBox[{
         RowBox[{"sp", "[", 
          RowBox[{"p1", ",", "p2"}], "]"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"Sqrt", "[", 
            RowBox[{"sp", "[", 
             RowBox[{"p1", ",", "p1"}], "]"}], "]"}], " ", 
           RowBox[{"Sqrt", "[", 
            RowBox[{"sp", "[", 
             RowBox[{"p2", ",", "p2"}], "]"}], "]"}]}], ")"}]}]}], "}"}], "/.", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"p1", ":>", "p1e"}], ",", 
        RowBox[{"p2", ":>", "p2e"}], ",", 
        RowBox[{"p3", ":>", "p3e"}]}], "}"}]}], "//", "UseLorentzLinearity"}],
     "//", "FullSimplify"}]}], ";"}]}], "Input",
 InitializationCell->
  True,ExpressionUUID->"55401da6-7a40-4bc1-8de4-104ab5cc60ea"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"dressingRules", "=", 
    RowBox[{
     RowBox[{"ReplaceRepeated", "[", 
      RowBox[{"#", ",", 
       RowBox[{"{", "\n", 
        RowBox[{
         RowBox[{
          RowBox[{"dressing", "[", 
           RowBox[{"GammaN", ",", 
            RowBox[{"{", 
             RowBox[{"cb", ",", "c"}], "}"}], ",", "1", ",", 
            RowBox[{"{", 
             RowBox[{"p1_", ",", "p2_"}], "}"}]}], "]"}], ":>", 
          RowBox[{
           RowBox[{"-", 
            RowBox[{"Zc", "[", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"sp", "[", 
               RowBox[{"p2", ",", "p2"}], "]"}], "]"}], "]"}]}], 
           RowBox[{"sp", "[", 
            RowBox[{"p2", ",", "p2"}], "]"}]}]}], ",", "\n", 
         RowBox[{
          RowBox[{"dressing", "[", 
           RowBox[{"GammaN", ",", 
            RowBox[{"{", 
             RowBox[{"A", ",", "A"}], "}"}], ",", "1", ",", 
            RowBox[{"{", 
             RowBox[{"p1_", ",", "p2_"}], "}"}]}], "]"}], ":>", 
          RowBox[{
           RowBox[{"ZA", "[", 
            RowBox[{"Sqrt", "[", 
             RowBox[{"sp", "[", 
              RowBox[{"p2", ",", "p2"}], "]"}], "]"}], "]"}], 
           RowBox[{"sp", "[", 
            RowBox[{"p2", ",", "p2"}], "]"}]}]}], ",", "\n", "\n", 
         RowBox[{
          RowBox[{"dressing", "[", 
           RowBox[{"InverseProp", ",", 
            RowBox[{"{", 
             RowBox[{"cb", ",", "c"}], "}"}], ",", "1", ",", 
            RowBox[{"{", 
             RowBox[{"p1_", ",", "p2_"}], "}"}]}], "]"}], ":>", 
          RowBox[{"-", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"Zc", "[", 
               RowBox[{"Sqrt", "[", 
                RowBox[{"sp", "[", 
                 RowBox[{"p2", ",", "p2"}], "]"}], "]"}], "]"}], 
              RowBox[{"sp", "[", 
               RowBox[{"p2", ",", "p2"}], "]"}]}], "+", 
             RowBox[{
              RowBox[{"RB", "[", 
               RowBox[{
                RowBox[{"k", "^", "2"}], ",", 
                RowBox[{"sp", "[", 
                 RowBox[{"p2", ",", "p2"}], "]"}]}], "]"}], 
              RowBox[{"Zc", "[", "k", "]"}]}]}], ")"}]}]}], ",", "\n", 
         RowBox[{
          RowBox[{"dressing", "[", 
           RowBox[{"InverseProp", ",", 
            RowBox[{"{", 
             RowBox[{"A", ",", "A"}], "}"}], ",", "1", ",", 
            RowBox[{"{", 
             RowBox[{"p1_", ",", "p2_"}], "}"}]}], "]"}], ":>", 
          RowBox[{
           RowBox[{
            RowBox[{"ZA", "[", 
             RowBox[{"Sqrt", "[", 
              RowBox[{"sp", "[", 
               RowBox[{"p2", ",", "p2"}], "]"}], "]"}], "]"}], 
            RowBox[{"sp", "[", 
             RowBox[{"p2", ",", "p2"}], "]"}]}], "+", 
           RowBox[{
            RowBox[{"RB", "[", 
             RowBox[{
              RowBox[{"k", "^", "2"}], ",", 
              RowBox[{"sp", "[", 
               RowBox[{"p2", ",", "p2"}], "]"}]}], "]"}], 
            RowBox[{"ZA", "[", "evP", "]"}]}]}]}], ",", "\n", "\n", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{"Angle", "-", 
            RowBox[{"resolved", " ", 
             RowBox[{"vertices", ":", " ", 
              RowBox[{
              "functions", " ", "of", " ", "the", " ", "three", " ", 
               "external", " ", "momenta"}]}]}]}], ",", " ", 
           RowBox[{
            RowBox[{
            "mapped", " ", "onto", " ", "the", "\n", "   ", "3", "D", " ", 
             "interpolators", " ", 
             RowBox[{
              RowBox[{"ZA3", "/", "ZAcbc"}], "/", "ZA4tadpole"}], " ", 
             "indexed", " ", "by", " ", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"|", "p1", "|"}], ",", 
                RowBox[{"|", "p2", "|"}], ",", 
                RowBox[{"cos", 
                 RowBox[{"(", 
                  RowBox[{"p1", ",", "p2"}], ")"}]}]}], ")"}], ".", "\n", 
              "   ", "ZA4SP"}], " ", "keeps", " ", "the", " ", "single"}], "-", 
            RowBox[{"point", " ", 
             RowBox[{"(", "symmetric", ")"}], " ", 
             RowBox[{"parametrisation", "."}]}]}]}], " ", "*)"}], "\n", 
         RowBox[{
          RowBox[{"dressing", "[", 
           RowBox[{"GammaN", ",", 
            RowBox[{"{", 
             RowBox[{"A", ",", "cb", ",", "c"}], "}"}], ",", "1", ",", 
            RowBox[{"{", 
             RowBox[{"p1_", ",", "p2_", ",", "p3_"}], "}"}]}], "]"}], ":>", 
          RowBox[{"ZAcbc", "[", 
           RowBox[{"p1", ",", "p2"}], "]"}]}], ",", "\n", 
         RowBox[{
          RowBox[{"dressing", "[", 
           RowBox[{"GammaN", ",", 
            RowBox[{"{", 
             RowBox[{"A", ",", "A", ",", "A"}], "}"}], ",", "1", ",", 
            RowBox[{"{", 
             RowBox[{"p1_", ",", "p2_", ",", "p3_"}], "}"}]}], "]"}], ":>", 
          RowBox[{"ZA3", "[", 
           RowBox[{"p1", ",", "p2"}], "]"}]}], ",", "\n", 
         RowBox[{
          RowBox[{"dressing", "[", 
           RowBox[{"GammaN", ",", 
            RowBox[{"{", 
             RowBox[{"A", ",", "A", ",", "A", ",", "A"}], "}"}], ",", "1", ",", 
            RowBox[{"{", 
             RowBox[{"p1_", ",", "p2_", ",", "p3_", ",", "p4_"}], "}"}]}], 
           "]"}], ":>", 
          RowBox[{"ZA4tadpole", "[", 
           RowBox[{"p1", ",", "p2"}], "]"}]}], ",", "\n", "\n", 
         RowBox[{
          RowBox[{"ZAcbc", "[", 
           RowBox[{"p1_", ",", "p2_"}], "]"}], ":>", 
          RowBox[{"ZAcbc", "@@", 
           RowBox[{"P3Patt", "[", 
            RowBox[{"p1", ",", "p2", ",", 
             RowBox[{
