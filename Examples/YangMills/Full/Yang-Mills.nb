            RowBox[{"p1", ",", "p2", ",", 
             RowBox[{
              RowBox[{"-", "p1"}], "-", "p2"}]}], "]"}]}]}], ",", "\n", "\n", 
         
         RowBox[{"nZA", "->", "6"}], ",", "\n", 
         RowBox[{"evP", ":>", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{"k", "^", "nZA"}], "+", "1"}], ")"}], "^", 
           RowBox[{"(", 
            RowBox[{"1", "/", "nZA"}], ")"}]}]}], ",", "\n", 
         RowBox[{"devP", ":>", 
          RowBox[{
           RowBox[{"k", "^", 
