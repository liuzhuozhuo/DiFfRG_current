             RowBox[{
              RowBox[{"-", "1"}], "+", "nZA"}], ")"}]}], " ", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"1", "+", 
              RowBox[{"k", "^", "nZA"}]}], ")"}], "^", 
            RowBox[{"(", 
             RowBox[{
              RowBox[{"-", "1"}], "+", 
              RowBox[{"1", "/", "nZA"}]}], ")"}]}]}]}], ",", "\n", 
         RowBox[{
          RowBox[{"dressing", "[", 
           RowBox[{"Rdot", ",", 
