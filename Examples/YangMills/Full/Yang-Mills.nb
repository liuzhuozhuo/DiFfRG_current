Notebook[{
Cell["\<\
DiFfRG / FunKit code generation - Yang-Mills (fully momentum-dependent, \
angle-resolved)\
\>", "Title",ExpressionUUID->"fffbd6c3-22ce-4f90-acd6-3f109cb2aaca"],

Cell["\<\
DiFfRG / FunKit code generation for the fully momentum-dependent \
(angle-resolved)
   Yang-Mills truncation. Ported to the current FunKit API, referencing
   Examples/YangMills/SP/Yang-Mills.m (propagators + codegen skeleton) and
   qcd-codes/sm/Quark-Meson.m (angle-resolved 3D-grid vertex kernels:
   P3Param, DeclareAnglesP34Dpqr, LogLogLinCoordinates, {p1,p2,cosp1p2}).
   Run headless with:  wolfram -script Yang-Mills.m\
\>", "Text",ExpressionUUID->"c27918e0-2a62-40f8-87c3-4bca4ca4ee51"],

Cell[BoxData[{
 RowBox[{"Get", "[", "\"\<DiFfRG`\>\"", "]"}], "\n", 
 RowBox[{
  RowBox[{"SetDirectory", "[", 
   RowBox[{"GetDirectory", "[", "]"}], "]"}], ";"}], "\n", 
 RowBox[{"DefineFormExecutable", "[", "\"\</usr/bin/tform -w16\>\"", 
  "]"}]}], "Input",
 InitializationCell->
  True,ExpressionUUID->"75d2e571-91c5-47d3-8033-8748e5228b74"],

Cell[BoxData[
 RowBox[{
  RowBox[{"fields", "=", " ", 
   RowBox[{"<|", "\n", 
    RowBox[{
     RowBox[{"\"\<Commuting\>\"", "->", " ", 
