Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"flowV", "=", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"WetterichEquation", "//", "FTruncate"}], "//", "FPlot"}], "//",
      "FRoute"}], "//", "FPrint"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"flowV", "=", 
   RowBox[{"flowV", "/.", "FeynmanRules"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"flowV", "=", 
   RowBox[{"FormTrace", "[", 
    RowBox[{
     RowBox[{"flowV", "[", "\"\<1-Loop\>\"", "]"}], "[", "\"\<Expression\>\"",
      "]"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"flowV", "=", 
   RowBox[{
    RowBox[{"ExpandScalarProductsFiniteT", "[", "flowV", "]"}], "//", 
    RowBox[{
     RowBox[{"SimplifyAllMomenta", "[", 
      RowBox[{"l1", ",", "#"}], "]"}], "&"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"flowV", "=", 
   RowBox[{"Assuming", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"-", "m2Pi"}], "-", 
        SuperscriptBox["l1", "2"], "-", 
        RowBox[{"RB", "[", 
         RowBox[{
          SuperscriptBox["k", "2"], ",", 
          SuperscriptBox["l1", "2"]}], "]"}]}], "<", "0"}], "&&", 
      RowBox[{
       RowBox[{
        RowBox[{"-", "m2Sigma"}], "-", 
        SuperscriptBox["l1", "2"], "-", 
        RowBox[{"RB", "[", 
         RowBox[{
          SuperscriptBox["k", "2"], ",", 
          SuperscriptBox["l1", "2"]}], "]"}]}], "<", "0"}]}], ",", 
     RowBox[{
      RowBox[{"Map", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"MatsubaraSum", "[", 
          RowBox[{"#", ",", "l10", ",", "T"}], "]"}], "&"}], ",", "flowV"}], 
       "]"}], "//", "FullSimplify"}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"MakeKernel", "[", 
  RowBox[{
   RowBox[{"SafeFiniteTFunctions", "[", 
    RowBox[{"flowV", ",", "T"}], "]"}], ",", "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"\"\<Name\>\"", "->", "\"\<V\>\""}], ",", "\[IndentingNewLine]", 
   RowBox[{"\"\<Integrator\>\"", "->", "\"\<Integrator_p2\>\""}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"\"\<d\>\"", "->", "3"}], ",", "\[IndentingNewLine]", 
   RowBox[{"\"\<AD\>\"", "->", "True"}], ",", "\[IndentingNewLine]", 
   RowBox[{"\"\<Device\>\"", "->", "\"\<TBB\>\""}], ",", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"\"\<Parameters\>\"", "->", "kernelParameterList"}], ",", 
   "\[IndentingNewLine]", 
   RowBox[{"\"\<IntegrationVariables\>\"", "\[Rule]", 
    RowBox[{"{", "\"\<l1\>\"", "}"}]}]}], "]"}], "\[IndentingNewLine]", 
 RowBox[{"UpdateFlows", "[", "\"\<ONFiniteTFlows\>\"", "]"}]}], "Input",
