# DiFfRG build test on Fedora 41 (CPU-only).
# Build from the repository root as context.
FROM fedora:41
LABEL type=diffrg-build-test

ARG threads=4

# Toolchain (cmake 3.30, gcc 14 -> C++20) + system dependencies. Fedora ships
# recent Boost/TBB/HDF5/SUNDIALS, so most are used directly (auto-detected);
# anything too old simply triggers the bundled build.
RUN dnf -y install \
        git cmake gcc gcc-c++ gcc-gfortran make \
        openblas-devel gsl-devel \
        boost-devel tbb-devel hdf5-devel sundials-devel \
        doxygen graphviz python3 patch which \
    && dnf clean all

WORKDIR /DiFfRG
COPY . /DiFfRG

RUN cmake -S /DiFfRG -B /build \
        -DCMAKE_BUILD_TYPE=Release \
        -DGPU=OFF -DMPI=OFF -DDiFfRG_DOCUMENTATION=OFF \
    && cmake --build /build -j ${threads} \
    && cmake -DDiFfRG_TEST=ON /build/DiFfRG/src/DiFfRG-build \
    && cmake --build /build/DiFfRG/src/DiFfRG-build -j ${threads}
