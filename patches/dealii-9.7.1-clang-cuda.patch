+// Boost.Math 1.88+ enables a CUDA/GPU code path under __CUDACC__ that is only
+// validated with nvcc; under clang-CUDA it produces __host__ vs
+// __host__ __device__ overload conflicts (e.g. boost::math::iround). This TU is
+// host-only, so include Boost.Math with the GPU path disabled. __CUDACC__ is
+// restored afterwards for the rest of the (Kokkos-using) translation unit.
+#ifdef __CUDACC__
+#  define DEAL_II_CUDACC_WAS_DEFINED
+#  undef __CUDACC__
+#endif
