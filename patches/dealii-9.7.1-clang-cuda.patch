 #include <vector>
 
 DEAL_II_NAMESPACE_OPEN
 
 namespace
 {
+  // Exact binomial coefficient C(n, k) for the small degrees used by Bernstein
+  // polynomials. This replaces boost::math::binomial_coefficient, whose header
+  // transitively includes the beta/round chain; in Boost 1.9x that mis-marks
+  // boost::math::iround for the GPU (its forward declaration is
+  // __host__ __device__ but the definition is __host__-only), which fails to
+  // compile when clang compiles this TU as CUDA via the Kokkos backend.
+  template <typename number>
+  number
+  binomial_coefficient(const unsigned int n, const unsigned int k)
+  {
+    number result = number(1);
+    for (unsigned int i = 0; i < k; ++i)
+      result = result * number(n - i) / number(i + 1);
+    return result;
+  }
+
   template <typename number>
   std::vector<number>
   get_bernstein_coefficients(const unsigned int k, const unsigned int n)
@@ -33,8 +47,8 @@ namespace
     for (unsigned int i = k; i < n + 1; ++i)
       {
         coeff[i] = ((i - k) % 2 == 0 ? 1 : -1) *
-                   boost::math::binomial_coefficient<number>(n, i) *
-                   boost::math::binomial_coefficient<number>(i, k);
+                   binomial_coefficient<number>(n, i) *
+                   binomial_coefficient<number>(i, k);
       }
     return coeff;
   }
